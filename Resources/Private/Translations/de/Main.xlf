          datatype="plaintext">
        <body>
            <trans-unit id="label.username">
                <source>Username</source>
                <target>Benutzername</target>
            </trans-unit>
            <trans-unit id="label.firstname">
                <source>Firstname</source>
                <target>Vorname</target>
            </trans-unit>
            <trans-unit id="label.lastname">
                <source>Lastname</source>
                <target>Nachname</target>
            </trans-unit>
            <trans-unit id="label.email">
                <source>E-mail</source>
                <target>E-Mail-Adresse</target>
            </trans-unit>
            <trans-unit id="label.role">
                <source>Role</source>
                <target>Benutzerrolle</target>
            </trans-unit>
            <trans-unit id="label.password">
                <source>Password</source>
                <target>Passwort</target>
            </trans-unit>
            <trans-unit id="label.password.change">
                <source>Set a new password</source>
                <target>Neues Passwort festlegen</target>
            </trans-unit>
            <trans-unit id="button.update">
                <source>Update</source>
                <target>Aktualisieren</target>
            </trans-unit>
            <trans-unit id="button.create">
                <source>Create user</source>
                <target>Benutzer erstellen</target>
            </trans-unit>
            <trans-unit id="flashMessage.login.logout-success.title">
                <source>Logged out</source>
                <target>Erfolgreich abgemeldet</target>
            </trans-unit>
            <trans-unit id="flashMessage.login.logout-success.msg">
                <source>Successfully logged out</source>
                <target>Erfolgreich angemeldet</target>
            </trans-unit>
            <trans-unit id="flashMessage.login.login-success.title">
                <source>Logged in</source>
                <target>Angemeldet</target>
            </trans-unit>
            <trans-unit id="flashMessage.login.login-success.msg">
                <source>Successfully logged in</source>
                <target>Erfolgreich angemeldet</target>
            </trans-unit>
            <trans-unit id="flashMessage.login.login-error.title">
                <source>Login failed</source>
                <target>Anmeldung fehlgeschlagen</target>
            </trans-unit>
            <trans-unit id="flashMessage.login.login-error.msg">
                <source>These credentials do not match, please try again.</source>
                <target>Anmeldedaten falsch. Bitte erneut probieren.</target>
            </trans-unit>
            <trans-unit id="flashMessage.user.create.msg">
                <source>Your user is created successfully. You can login now with this user.</source>
                <target>Ihr Benutzer wurde erfolgreich erstellt. Sie können sich jetzt mit diesem Benutzer anmelden.</target>
            </trans-unit>
            <trans-unit id="flashMessage.user.create.title">
                <source>Your user is created!</source>
                <target>Ihr Benutzer ist erstellt!</target>
            </trans-unit>
            <trans-unit id="flashMessage.user.create.duplicate.title">
                <source>User already exists</source>
                <target>Benutzer existiert bereits</target>
            </trans-unit>
            <trans-unit id="flashMessage.user.create.duplicate.msg">
                <source>A user with this email address or username already exists.</source>
                <target>Ein Benutzer mit dieser E-Mail-Adresse oder diesem Benutzernamen existiert bereits.</target>
            </trans-unit>
            <trans-unit id="action.resetPassword">
                <source>Forgot your password?</source>
                <target>Passwort vergessen?</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.label.legend">
                <source>Set a new password for {0}</source>
                <target>Neues Passwort setzen für {0}</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.label.email">
                <source>Enter your e-mail address here</source>
                <target>Tragen Sie hier Ihre E-Mail-Adresse ein</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.label.login">
                <source>Login</source>
                <target>Anmelden</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.tooltip.email">
                <source>If we can match your e-mail address to an existing account, we will send you a link with which
                    you reset your password.
                </source>
                <target>Falls bereits ein Benutzeraccount mit dieser E-Mail-Adresse existiert, senden wir Ihnen einen
                    Link zu, mit dem Sie Ihr Passwort zurücksetzen können.
                </target>
            </trans-unit>
            <trans-unit id="action.resetPassword.button.submit">
                <source>Yes, please send me the link!</source>
                <target>Ja, ich möchte einen Link erhalten!</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.label.password">
                <source>Set the new password</source>
                <target>Neues Passwort festlegen</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.label.passwordRepeat">
                <source>Repeat the new password</source>
                <target>Neues Passwort wiederholen</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.button.submitPasswords">
                <source>Reset the password</source>
                <target>Jetzt neues Passwort festlegen</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.messages.error">
                <source>Your passwords do not match.</source>
                <target>Die Passwörter stimmen nicht überein.</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.messages.accountNotFound">
                <source>The email address you provided is not linked to an existing account.</source>
                <target>Für diese E-Mail-Adresse existiert noch kein Benutzeraccount.</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.messages.emailSent">
                <source>Please check your inbox for an email with a link to reset your password.</source>
                <target>Wir haben Ihnen einen Link gesendet. Bitte prüfen Sie Ihren Posteingang.</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.messages.invalidToken">
                <source>The token has expired, please retry.</source>
                <target>Der Link ist abgelaufen. Bitte versuchen Sie es noch einmal.</target>
            </trans-unit>
            <trans-unit id="action.resetPassword.messages.success">
                <source>The password has been successfully changed.</source>
                <target>Das Passwort wurde erfolgreich geändert.</target>
            </trans-unit>
            <trans-unit id="nodeTypes.groups.frontendLogin">
              <source>Frontend Login</source>
              <target>Frontend Login</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.title">
                <source>Auto Approved Domains</source>
                <target>Automatisch freigegebene Domains</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.description">
                <source>Users with an email address from these domains will be automatically approved and assigned the auto-approved role.</source>
                <target>Benutzer mit einer E-Mail-Adresse von diesen Domains werden automatisch freigegeben und erhalten die entsprechende Rolle.</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.countMessage">
                <source>There are currently {0} domains registered.</source>
                <target>Es sind aktuell &lt;strong&gt;{0}&lt;/strong&gt; Domains registriert.</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.table.header.domain">
                <source>Domain</source>
                <target>Domain</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.table.header.actions">
                <source>Actions</source>
                <target>Aktionen</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.form.add.title">
                <source>Add new domains</source>
                <target>Neue Domains anlegen</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.form.add.label.domain">
                <source>Domains (one per line)</source>
                <target>Domains (eine pro Zeile)</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.form.add.button.submit">
                <source>Add domains</source>
                <target>Domains anlegen</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.form.add.placeholder">
                <source>example.com
sub.example.com</source>
                <target>example.com
sub.example.com</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.action.delete.confirm">
                <source>Delete domain?</source>
                <target>Domain löschen?</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.action.delete.title">
                <source>Delete domain {0}</source>
                <target>Domain {0} löschen</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.create.success">
                <source>Added {0} domains.</source>
                <target>{0} Domains hinzugefügt.</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.create.partialSuccess">
                <source>Added {0} domains. Skipped {1} invalid and {2} duplicates.</source>
                <target>{0} Domains hinzugefügt. {1} ungültige und {2} Duplikate wurden übersprungen.</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.create.partialSuccess.invalid">
                <source>Added {0} domains. Skipped {1} invalid.</source>
                <target>{0} Domains hinzugefügt. {1} ungültige wurden übersprungen.</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.create.partialSuccess.duplicates">
                <source>Added {0} domains. Skipped {1} duplicates.</source>
                <target>{0} Domains hinzugefügt. {1} Duplikate wurden übersprungen.</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.create.error.noneAdded">
                <source>No domains were added. Please check the format and duplicates.</source>
                <target>Es wurden keine Domains hinzugefügt. Bitte prüfen Sie das Format und mögliche Duplikate.</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.create.error.duplicate">
                <source>Domain already exists</source>
                <target>Domain existiert bereits</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.create.error.invalidFormat">
                <source>The domain format is invalid. It should be like domain.tld or sub.domain.tld.</source>
                <target>Das Domain-Format ist ungültig. Es sollte wie domain.tld oder sub.domain.tld sein.</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.delete.success">
                <source>Domain removed</source>
                <target>Domain entfernt</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.delete.error.notFound">
                <source>Domain not found</source>
                <target>Domain nicht gefunden</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.error.title">
                <source>Error</source>
                <target>Fehler</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.action.clearAll.label">
                <source>Clear all domains</source>
                <target>Alle Domains löschen</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.action.clearAll.confirm">
                <source>Are you sure you want to remove all domains?</source>
                <target>Sind Sie sicher, dass Sie alle Domains entfernen möchten?</target>
            </trans-unit>
            <trans-unit id="backend.autoApprovedDomains.flashMessage.deleteAll.success">
                <source>All domains have been removed.</source>
                <target>Alle Domains wurden entfernt.</target>
            </trans-unit>
